<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram id="keep-alive-data-flow" name="KeepAlive 完整数据流">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;子应用 KeepAlive 缓存清理：完整数据流&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=20;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="430" y="20" width="740" height="40" as="geometry" />
        </mxCell>

        <mxCell id="start" value="&lt;b&gt;用户 / 子应用&lt;/b&gt;&lt;br&gt;关闭 Tab" style="shape=mxgraph.flowchart.terminator;rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="620" y="90" width="360" height="60" as="geometry" />
        </mxCell>

        <mxCell id="host-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF2FF;strokeColor=#0A1A3C;strokeWidth=3;dashed=1;dashPattern=8 4;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="120" y="200" width="1360" height="200" as="geometry" />
        </mxCell>
        <mxCell id="host-label" value="&lt;b&gt;主应用&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=15;fillColor=none;strokeColor=none;fontColor=#0A1A3C;" vertex="1" parent="1">
          <mxGeometry x="145" y="205" width="120" height="28" as="geometry" />
        </mxCell>
        <mxCell id="host-remove-tab" value="&lt;b&gt;tabBar.removeTab(fullPath)&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;1. 删除 tabs Map 对应项&lt;br&gt;2. 处理导航跳转&lt;br&gt;3. emitTabRemove({ fullPath })&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=3;shadow=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="270" y="255" width="420" height="95" as="geometry" />
        </mxCell>
        <mxCell id="runtime-event" value="&lt;b&gt;运行时事件&lt;/b&gt;&lt;br&gt;channel.emit(&#39;tab:remove&#39;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=3;shadow=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="267" width="300" height="70" as="geometry" />
        </mxCell>

        <mxCell id="sub-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=3;dashed=1;dashPattern=8 4;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="120" y="450" width="1360" height="500" as="geometry" />
        </mxCell>
        <mxCell id="sub-label" value="&lt;b&gt;子应用&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=15;fillColor=none;strokeColor=none;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="145" y="455" width="120" height="28" as="geometry" />
        </mxCell>
        <mxCell id="listener" value="&lt;b&gt;useTabRemoveListener handler&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;1. matchActiveRule() 过滤&lt;br&gt;2. stripActiveRule() 还原本地路径&lt;br&gt;3. removeTab(localFullPath)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=3;shadow=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="250" y="520" width="420" height="95" as="geometry" />
        </mxCell>
        <mxCell id="remove-tab" value="&lt;b&gt;useKeepAlive.removeTab(localFullPath)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=3;shadow=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="760" y="535" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="is-active" value="&lt;b&gt;是否当前激活页？&lt;/b&gt;" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=3;fontStyle=1;fontSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="655" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="wait-route-change" value="&lt;b&gt;等待路由切走&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;watch(() =&amp;gt; route.fullPath)&lt;br&gt;确认当前页已不再激活&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=3;shadow=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1090" y="665" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cleanup-tab" value="&lt;b&gt;cleanupTab(fullPath)&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;tabMetaMap.delete(fullPath) → include 重新计算&lt;br&gt;nextTick(() =&amp;gt; wrapperMap.delete(fullPath))&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=3;shadow=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="590" y="820" width="420" height="90" as="geometry" />
        </mxCell>

        <mxCell id="vue-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=3;dashed=1;dashPattern=8 4;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="380" y="990" width="840" height="120" as="geometry" />
        </mxCell>
        <mxCell id="vue-label" value="&lt;b&gt;Vue / KeepAlive&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=15;fillColor=none;strokeColor=none;fontColor=#EF6C00;" vertex="1" parent="1">
          <mxGeometry x="405" y="995" width="180" height="28" as="geometry" />
        </mxCell>
        <mxCell id="destroy-cache" value="&lt;b&gt;KeepAlive 销毁对应缓存实例&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;目标页面实例被安全清理&lt;/font&gt;" style="shape=mxgraph.flowchart.terminator;rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="555" y="1035" width="490" height="50" as="geometry" />
        </mxCell>

        <mxCell id="edge-start-host" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#1565C0;endArrow=classic;" edge="1" source="start" target="host-remove-tab" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-host-event" value="&lt;b&gt;emitTabRemove&lt;/b&gt;" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#1565C0;endArrow=classic;" edge="1" source="host-remove-tab" target="runtime-event" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-event-listener" value="&lt;b&gt;tab:remove&lt;/b&gt;" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#2E7D32;endArrow=classic;" edge="1" source="runtime-event" target="listener" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-listener-remove" value="&lt;b&gt;localFullPath&lt;/b&gt;" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#2E7D32;endArrow=classic;" edge="1" source="listener" target="remove-tab" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-remove-decision" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#2E7D32;endArrow=classic;" edge="1" source="remove-tab" target="is-active" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-decision-cleanup-no" value="&lt;b&gt;否&lt;/b&gt;" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#2E7D32;endArrow=classic;" edge="1" source="is-active" target="cleanup-tab" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-decision-wait-yes" value="&lt;b&gt;是&lt;/b&gt;" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#D6B656;endArrow=classic;" edge="1" source="is-active" target="wait-route-change" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-wait-cleanup" value="&lt;font color=&quot;#D6B656&quot;&gt;路由已切走&lt;/font&gt;" style="html=1;edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#D6B656;endArrow=classic;" edge="1" source="wait-route-change" target="cleanup-tab" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-cleanup-destroy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;jumpStyle=arc;jumpSize=6;strokeWidth=4;strokeColor=#EF6C00;endArrow=classic;" edge="1" source="cleanup-tab" target="destroy-cache" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend-container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;strokeWidth=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="120" y="1135" width="780" height="50" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="&lt;b&gt;图例：&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=11;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="135" y="1145" width="50" height="24" as="geometry" />
        </mxCell>
        <mxCell id="legend-main" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="190" y="1148" width="18" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend-main-text" value="主应用链路" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="214" y="1142" width="80" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-sub" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="315" y="1148" width="18" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend-sub-text" value="子应用链路" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="339" y="1142" width="80" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-guard" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="440" y="1148" width="18" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend-guard-text" value="等待 / 条件判断" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="464" y="1142" width="110" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-vue" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="1148" width="18" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legend-vue-text" value="Vue / KeepAlive 结果" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="624" y="1142" width="140" height="28" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
