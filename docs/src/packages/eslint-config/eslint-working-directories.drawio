        <mxCell id="edge-left-3-4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1565C0;strokeWidth=4;endArrow=classic;jumpStyle=arc;jumpSize=6;" edge="1" source="left-step3" target="left-step4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== 右列流程：mock-server ===== -->

        <!-- 步骤1：打开文件 -->
        <mxCell id="right-step1" value="&lt;b&gt;打开 apps/mock-server/routes/xxx.ts&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#E65100;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="750" y="95" width="380" height="50" as="geometry" />
        </mxCell>

        <!-- 步骤2：切换工作目录 -->
        <mxCell id="right-step2" value="&lt;b&gt;ESLint 插件切换工作目录到&lt;br&gt;apps/mock-server/&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565C0;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="750" y="175" width="380" height="55" as="geometry" />
        </mxCell>

        <!-- 步骤3：读取配置 -->
        <mxCell id="right-step3" value="&lt;b&gt;读取 apps/mock-server/eslint.config.js&lt;br&gt;（使用 base 配置）&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565C0;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;arcSize=20;" vertex="1" parent="1">
