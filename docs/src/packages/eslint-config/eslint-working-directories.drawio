          <mxGeometry x="730" y="60" width="420" height="25" as="geometry" />
        </mxCell>

        <!-- ===== 左列流程：main-app ===== -->

        <!-- 步骤1：打开文件 -->
        <mxCell id="left-step1" value="&lt;b&gt;打开 apps/main-app/src/App.vue&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#E65100;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="150" y="95" width="380" height="50" as="geometry" />
        </mxCell>

        <!-- 步骤2：切换工作目录 -->
        <mxCell id="left-step2" value="&lt;b&gt;ESLint 插件切换工作目录到&lt;br&gt;apps/main-app/&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565C0;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="150" y="175" width="380" height="55" as="geometry" />
        </mxCell>

        <!-- 步骤3：读取配置 -->
        <mxCell id="left-step3" value="&lt;b&gt;读取 apps/main-app/eslint.config.js&lt;br&gt;（使用 vue3 配置）&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565C0;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="150" y="260" width="380" height="55" as="geometry" />
        </mxCell>

        <!-- 步骤4：结果 -->
        <mxCell id="left-step4" value="&lt;b&gt;正确理解 Vue 模板语法、&lt;br&gt;auto-import globals、&lt;br&gt;main-app 的 tsconfig 边界&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="150" y="345" width="380" height="65" as="geometry" />
