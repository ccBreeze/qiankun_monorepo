        <!-- 步骤4：结果 -->
        <mxCell id="right-step4" value="&lt;b&gt;只应用 TypeScript 规则，&lt;br&gt;不会误报 Vue 相关错误&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=3;shadow=1;fontStyle=1;fontSize=13;arcSize=20;" vertex="1" parent="1">
