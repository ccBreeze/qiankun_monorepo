        <mxCell id="title" value="&lt;b&gt;ESLint workingDirectories 工作流程&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=20;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="800" height="35" as="geometry" />
        </mxCell>

        <!-- 左列标签：main-app 示例 -->
        <mxCell id="label-left" value="&lt;b&gt;示例 A：Vue 子应用&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=14;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="130" y="60" width="420" height="25" as="geometry" />
        </mxCell>

        <!-- 右列标签：mock-server 示例 -->
