        <mxCell id="constraint-ts" value="&lt;b&gt;必须在 ESLint 推荐之后&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;需禁用冲突的原生规则&lt;br&gt;如 no-unused-vars → @typescript-eslint/no-unused-vars&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontStyle=0;fontSize=11;fontColor=#333333;arcSize=15;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
